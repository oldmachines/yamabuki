        .{ .path = "CHIP/GSU/GSUTest/CMP/GSUCMP.sfc", .hash = 0x2610419f305b2e19, .steps = 3732528, .cycles = 85768338, .frames = 240 },
        .{ .path = "CHIP/GSU/GSUTest/DEC/GSUDEC.sfc", .hash = 0xa05d750ac24e8515, .steps = 3737956, .cycles = 85768342, .frames = 240 },
