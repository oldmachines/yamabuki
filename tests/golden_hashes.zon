// Golden framebuffer hashes for the ROM runner (`zig build test-roms`).
//
// Each hash is the FNV-1a of the RGB565 framebuffer after `frames` frames of a
// PeterLemon/SNES test ROM (fetched into test-data/snes-roms by
// tools/fetch_test_data.sh — the ROMs themselves are never committed). Hashes
// were minted after visually inspecting the .ppm output and are deterministic
// across Debug/ReleaseFast and target architectures.
//
// This set covers the M3 fast renderer (BG mode 0 2bpp + sprites) and, from
// M4.1, the planar BG modes with 4bpp and 8bpp depth (modes 2/3/4). Windows,
// color math, mosaic, hi-res, and Mode 7 ROMs join as those slices land.
//
// `steps` (CPU instructions/interrupts retired) and `cycles` (master cycles
// elapsed) are deterministic per-run work counts — a perf-regression baseline
// checked alongside the framebuffer hash. A `steps`/`cycles` of 0 means
// "not yet baselined" and is not gated. They are deterministic across
// Debug/ReleaseFast and architectures, same as the hashes.
.{
    .frames = 16,
    .roms = .{
        .{ .path = "HelloWorld/HelloWorld.sfc", .hash = 0x14ecd91531a2ca4c, .steps = 158338, .cycles = 5717916 },
        .{ .path = "PPU/BGMAP/8x8/2BPP/8x8BG1Map2BPP32x328PAL/8x8BG1Map2BPP32x328PAL.sfc", .hash = 0x3ad32cfefc54c6be, .steps = 154307, .cycles = 5717916 },
        .{ .path = "PPU/BGMAP/8x8/2BPP/8x8BG3Map2BPP32x328PAL/8x8BG3Map2BPP32x328PAL.sfc", .hash = 0xc9212acfe3a51a25, .steps = 154307, .cycles = 5717916 },
        .{ .path = "PPU/Rings/Rings.sfc", .hash = 0x20dc65b09f98c115, .steps = 152248, .cycles = 5717906 },
        // M4.1: BG2/BG4 2bpp (mode 0 layer coverage), 4bpp (mode 1/2), 8bpp (modes 3/4).
        .{ .path = "PPU/BGMAP/8x8/2BPP/8x8BG2Map2BPP32x328PAL/8x8BG2Map2BPP32x328PAL.sfc", .hash = 0xc9212acfe3a51a25, .steps = 154307, .cycles = 5717916 },
        .{ .path = "PPU/BGMAP/8x8/2BPP/8x8BG4Map2BPP32x328PAL/8x8BG4Map2BPP32x328PAL.sfc", .hash = 0xc9212acfe3a51a25, .steps = 154307, .cycles = 5717916 },
        .{ .path = "PPU/BGMAP/8x8/4BPP/8x8BGMap4BPP32x328PAL/8x8BGMap4BPP32x328PAL.sfc", .hash = 0xca039a735b43ef3e, .steps = 149835, .cycles = 5717904 },
        .{ .path = "PPU/BGMAP/8x8/8BPP/32x32/8x8BGMap8BPP32x32.sfc", .hash = 0xd74dbf7e9e3fcfbc, .steps = 154031, .cycles = 5717908 },
        .{ .path = "PPU/BGMAP/8x8/8BPP/32x64/8x8BGMap8BPP32x64.sfc", .hash = 0xce39d1f87fb4187e, .steps = 151667, .cycles = 5717914 },
        .{ .path = "PPU/BGMAP/8x8/8BPP/64x32/8x8BGMap8BPP64x32.sfc", .hash = 0xce39d1f87fb4187e, .steps = 149934, .cycles = 5717916 },
        .{ .path = "PPU/BGMAP/8x8/8BPP/64x64/8x8BGMap8BPP64x64.sfc", .hash = 0xce39d1f87fb4187e, .steps = 146646, .cycles = 5717932 },
        .{ .path = "PPU/BGMAP/8x8/8BPP/TileFlip/8x8BGMapTileFlip.sfc", .hash = 0x0aee22f7096e9c25, .steps = 158610, .cycles = 5717918 },
        // M4.2: mode-3 scene. NB: this demo's mosaic level is input-driven, so it
        // renders with mosaic off headless; the mosaic quantization itself is
        // covered by the inline unit test, not this hash.
        .{ .path = "PPU/Mosaic/Mode3/MosaicMode3.sfc", .hash = 0x530d2729b590abaf, .steps = 140836, .cycles = 5717922 },
        // M4.4: multi-window layer clipping (TMW carves the BG into regions,
        // backdrop showing through). WindowHDMA uses the color-math spotlight and
        // is deferred to the color-math slice (renders full without it).
        .{ .path = "PPU/Window/WindowMultiHDMA/WindowMultiHDMA.sfc", .hash = 0x5b00df0115ff4a61, .steps = 146300, .cycles = 5717930 },
        // M4.6: Mode 7 affine plane. RotZoom (rotate+zoom) and Perspective
        // (per-scanline HDMA matrix) exercise the transform; StarWars boots to its
        // intro at frame 16 (the crawl is later) and locks that render.
        // RotZoom/Perspective/Mode7HDMA were re-minted in M6: they poll the
        // joypad, which used to read open-bus garbage (phantom presses) and
        // now correctly reads a neutral pad. `.ppm`s re-eyeballed.
        .{ .path = "PPU/Mode7/RotZoom/RotZoom.sfc", .hash = 0x8ba211f2fc899f95, .steps = 150702, .cycles = 5717926 },
        .{ .path = "PPU/Mode7/Perspective/Perspective.sfc", .hash = 0xca6c36e8a6140b02, .steps = 138331, .cycles = 5717928 },
        .{ .path = "PPU/Mode7/StarWars/StarWars.sfc", .hash = 0x72489634a8ee621d, .steps = 158867, .cycles = 5717910 },
        // M4.5: HDMA-driven register goldens. WindowHDMA (deferred from M4.4)
        // is an *inverted* window with HDMA'd WH0/WH1 edges over a green
        // backdrop — its first band is the empty-window [1,0] edge case; the
        // M4.4 note that it needed color math was a misdiagnosis (per source it
        // is TMW-only, and it rendered identically before this slice).
        // Mode7HDMA drives the M7 matrix per scanline (perspective ground
        // plane); WaveHDMA sine-displaces BG1HOFS per line. No PeterLemon ROM
        // exercises CGADSUB color math directly (the Blend/HiColor ones need
        // pseudo-hires, M4.7), so blending itself is guarded by unit tests.
        .{ .path = "PPU/Window/WindowHDMA/WindowHDMA.sfc", .hash = 0x7bafda0faf223f57, .steps = 146450, .cycles = 5717916 },
        .{ .path = "PPU/HDMA/Mode7HDMA/Mode7HDMA.sfc", .hash = 0xbb802b13b82f8f0e, .steps = 148719, .cycles = 5717916 },
        .{ .path = "PPU/HDMA/WaveHDMA/WaveHDMA.sfc", .hash = 0x6d5ebfbf9af5178d, .steps = 137718, .cycles = 5717924 },
        // M4.7: the Blend/HiColor set is the real CGADSUB exercise (M4.5's
        // survey missed that these blend at 256 wide, no pseudo-hires): BG1 on
        // the main screen, BG2 on the sub screen, added per pixel for hundreds
        // of apparent colors. The HDMA/HiColor*PerTileRow ROMs stay unminted:
        // they race the beam (H-IRQ + latched V-counter + mid-scanline CGRAM
        // DMA) and need the accurate core's sub-line timing (M8).
        .{ .path = "PPU/Blend/HiColor/HiColor575Myst/HiColor575Myst.sfc", .hash = 0x648efce3a804de22, .steps = 140944, .cycles = 5717918 },
        .{ .path = "PPU/Blend/HiColor/HiColor3840/HiColor3840.sfc", .hash = 0xd7598be40b7f8ce5, .steps = 143917, .cycles = 5717904 },
        .{ .path = "PPU/Blend/HiColor/HiColor1241DLair/HiColor1241DLair.sfc", .hash = 0xffee96ffe902ac1a, .steps = 140284, .cycles = 5717924 },
        // M4.7: mode 5 hi-res (512-wide, 16-wide tiles). InterlaceFont locks a
        // crisp hi-res font sheet; InterlaceRPG a full 512-wide scene.
        // MosaicMode5's mosaic level is input-driven (renders mosaic-off
        // headless, same as MosaicMode3) and shows the same moogle image as
        // InterlaceMoogle — identical hashes are expected. The
        // Interlace{Myst,Simpsons}HDMA ROMs stay unminted: they need true
        // interlaced 448-line field rendering (the HDMA'd tile base assumes
        // field-interleaved rows), which the 224-line fast core doesn't model.
        .{ .path = "PPU/Mosaic/Mode5/MosaicMode5.sfc", .hash = 0xf2e09c4f161ff725, .steps = 153077, .cycles = 5717918 },
        .{ .path = "PPU/Interlace/InterlaceFont/InterlaceFont.sfc", .hash = 0x109a188a73e19540, .steps = 155006, .cycles = 5717912 },
        .{ .path = "PPU/Interlace/InterlaceMoogle/InterlaceMoogle.sfc", .hash = 0xf2e09c4f161ff725, .steps = 153077, .cycles = 5717924 },
        .{ .path = "PPU/Interlace/InterlaceRPG/InterlaceRPG.sfc", .hash = 0x0070e006af27c4ed, .steps = 147948, .cycles = 5717928 },
        // M5: SPC700 end-to-end. The CPUTest ROMs upload an SPC program via
        // the HLE boot handshake, run opcode self-tests on the audio CPU, and
        // hand results back through the mailbox ports — at 180 frames each
        // shows a verified PASS screen (the suites keep cycling sub-tests
        // beyond that; 180 is a deterministic mid-suite checkpoint).
        .{ .path = "CPUTest/SPC700/ADC/SPC700ADC.sfc", .hash = 0x420e94634463f1b1, .steps = 2959431, .cycles = 64326262, .frames = 180 },
        .{ .path = "CPUTest/SPC700/AND/SPC700AND.sfc", .hash = 0x76fd9f2391509961, .steps = 2959433, .cycles = 64326260, .frames = 180 },
        .{ .path = "CPUTest/SPC700/DEC/SPC700DEC.sfc", .hash = 0x6137701a5b5fe4dd, .steps = 2960932, .cycles = 64326274, .frames = 180 },
        .{ .path = "CPUTest/SPC700/EOR/SPC700EOR.sfc", .hash = 0x28ee6457ca7887e5, .steps = 2959433, .cycles = 64326260, .frames = 180 },
        .{ .path = "CPUTest/SPC700/INC/SPC700INC.sfc", .hash = 0x82d485c6a584a90d, .steps = 2960932, .cycles = 64326274, .frames = 180 },
        .{ .path = "CPUTest/SPC700/ORA/SPC700ORA.sfc", .hash = 0xc3c1b3812f314f75, .steps = 2959435, .cycles = 64326270, .frames = 180 },
        .{ .path = "CPUTest/SPC700/SBC/SPC700SBC.sfc", .hash = 0x563dc88db83a4ab9, .steps = 2959431, .cycles = 64326284, .frames = 180 },
        // M5b: the S-DSP. These SPC700 demo ROMs render a black screen by
        // design (audio-only; the CPU side uploads a driver then spins) — the
        // shared framebuffer hash guards the boot path, and `audio` locks the
        // FNV of the whole 32 kHz stereo stream. Together they exercise BRR
        // decode + gaussian interpolation (PlayBRRSample, SpeechSynth), the
        // noise LFSR (PlayNoise), pitch modulation (PitchMod), and full music
        // drivers with envelopes/echo (Axel-F, Twinkle, FFVIIPrelude,
        // ItaloTest). Audio hashes are identical across Debug/ReleaseFast.
        .{ .path = "SPC700/Axel-F/Axel-F.sfc", .hash = 0x045b5aaabee52325, .steps = 820223, .cycles = 21442096, .frames = 60, .audio = 0xe2fbd615d2d54f15 },
        .{ .path = "SPC700/Twinkle/Twinkle.sfc", .hash = 0x045b5aaabee52325, .steps = 827094, .cycles = 21442110, .frames = 60, .audio = 0x89372e2a36d5a179 },
        .{ .path = "SPC700/PlayBRRSample/PlayBRRSample.sfc", .hash = 0x045b5aaabee52325, .steps = 826808, .cycles = 21442118, .frames = 60, .audio = 0x9055e343ae029d45 },
        .{ .path = "SPC700/PlayNoise/PlayNoise.sfc", .hash = 0x045b5aaabee52325, .steps = 827579, .cycles = 21442110, .frames = 60, .audio = 0xfe7dd7c9fb55a8dd },
        .{ .path = "SPC700/PitchMod/PitchMod.sfc", .hash = 0x045b5aaabee52325, .steps = 826513, .cycles = 21442110, .frames = 60, .audio = 0x547d966e83d08911 },
        .{ .path = "SPC700/SpeechSynth/SpeechSynth.sfc", .hash = 0x045b5aaabee52325, .steps = 817604, .cycles = 21442104, .frames = 60, .audio = 0xb77345d8c1f5609d },
        .{ .path = "SPC700/FFVIIPrelude/FFVIIPrelude.sfc", .hash = 0x045b5aaabee52325, .steps = 820014, .cycles = 21442108, .frames = 60, .audio = 0x0f8608c69ae09dcd },
        .{ .path = "SPC700/ItaloTest/ItaloTest.sfc", .hash = 0x045b5aaabee52325, .steps = 822557, .cycles = 21442098, .frames = 60, .audio = 0x813406a382940732 },
        // M9a: Super FX (GSU). The 31 GSUTest ROMs run hardware-verified opcode
        // checks on the GSU and print PASS/FAIL per case (a failure freezes the
        // screen in a FAIL loop, so these hashes prove every case passed); the 27
        // plot demos exercise PLOT/RPIX bitplane rendering across 2/4/8bpp and all
        // three screen heights, and match krom's reference captures pixel-for-pixel
        // modulo the emulator's global one-line display offset (see ROADMAP).
        .{ .path = "CHIP/GSU/GSUTest/ADC/GSUADC.sfc", .hash = 0xc3385cd437acdc71, .steps = 3635008, .cycles = 85768356, .frames = 240 },
